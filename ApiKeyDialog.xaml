<Window x:Class="VoiceBookStudio.Views.ApiKeyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure AI — VoiceBook Studio"
        Width="480" Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AutomationProperties.Name="Configure Anthropic API key dialog">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Heading -->
        <TextBlock Grid.Row="0"
                   Text="Anthropic API Key"
                   FontSize="15"
                   FontWeight="Bold"
                   AutomationProperties.Name="Anthropic API Key heading"/>

        <!-- Instructions -->
        <TextBlock Grid.Row="2"
                   TextWrapping="Wrap"
                   FontSize="12"
                   Foreground="#555"
                   Text="Paste your Anthropic API key below. Get one free at console.anthropic.com — keys start with sk-ant-"
                   AutomationProperties.Name="Instructions: Paste your Anthropic API key. Get one free at console dot anthropic dot com. Keys start with sk-ant-"/>

        <!-- Key label -->
        <TextBlock Grid.Row="4"
                   Text="API Key:"
                   FontSize="13"
                   AutomationProperties.Name="API Key label"/>

        <!-- Key input (PasswordBox for masking, with show-toggle) -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <PasswordBox x:Name="KeyBox"
                         Grid.Column="0"
                         FontSize="13"
                         Padding="4"
                         TabIndex="1"
                         AutomationProperties.Name="API key input field"
                         AutomationProperties.HelpText="Paste your Anthropic API key here. The key will be hidden for security."
                         KeyDown="KeyBox_KeyDown"/>

            <Button Grid.Column="2"
                    x:Name="ShowHideButton"
                    Content="Show"
                    FontSize="12"
                    Padding="8,4"
                    MinWidth="50"
                    TabIndex="2"
                    Click="ShowHideButton_Click"
                    AutomationProperties.Name="Show or hide API key"
                    AutomationProperties.HelpText="Toggle visibility of the API key text"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="ClearButton"
                    Content="Clear Key"
                    Margin="0,0,8,0"
                    TabIndex="3"
                    Click="ClearButton_Click"
                    AutomationProperties.Name="Clear saved API key"/>
            <Button Content="Cancel"
                    IsCancel="True"
                    Margin="0,0,8,0"
                    TabIndex="4"
                    AutomationProperties.Name="Cancel"/>
            <Button Content="Save"
                    IsDefault="True"
                    TabIndex="5"
                    Click="SaveButton_Click"
                    AutomationProperties.Name="Save API key"/>
        </StackPanel>
    </Grid>
</Window>
