<Window x:Class="VoiceBookStudio.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VoiceBookStudio.ViewModels"
        xmlns:panels="clr-namespace:VoiceBookStudio.Views.Panels"
        Title="{Binding WindowTitle}"
        MinWidth="900" MinHeight="600"
        Width="1200" Height="750"
        WindowStartupLocation="CenterScreen"
        AutomationProperties.Name="VoiceBook Studio main window">

    <Window.InputBindings>
        <KeyBinding Key="N"      Modifiers="Ctrl"       Command="{Binding NewProjectCommand}"/>
        <KeyBinding Key="O"      Modifiers="Ctrl"       Command="{Binding OpenProjectCommand}"/>
        <KeyBinding Key="S"      Modifiers="Ctrl"       Command="{Binding SaveProjectCommand}"/>
        <KeyBinding Key="S"      Modifiers="Ctrl+Shift" Command="{Binding SaveProjectAsCommand}"/>
        <KeyBinding Key="I"      Modifiers="Ctrl"       Command="{Binding ImportDocumentCommand}"/>
        <KeyBinding Key="A"      Modifiers="Ctrl"       Command="{Binding AddChapterCommand}"/>
        <KeyBinding Key="D"      Modifiers="Ctrl"       Command="{Binding RenameChapterCommand}"/>
        <KeyBinding Key="Delete" Modifiers="Ctrl"       Command="{Binding DeleteChapterCommand}"/>
        <KeyBinding Key="Up"     Modifiers="Alt"        Command="{Binding MoveChapterUpCommand}"/>
        <KeyBinding Key="Down"   Modifiers="Alt"        Command="{Binding MoveChapterDownCommand}"/>
        <KeyBinding Key="F"      Modifiers="Ctrl"       Command="{Binding RunAiFeedbackCommand}" CommandParameter="comprehensive"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============================================================
             MENU BAR
             ============================================================ -->
        <Menu Grid.Row="0" AutomationProperties.Name="Main menu">

            <MenuItem Header="_File" AutomationProperties.Name="File menu">
                <MenuItem Header="_New Project"
                          Command="{Binding NewProjectCommand}"
                          InputGestureText="Ctrl+N"
                          AutomationProperties.Name="New project, Control N"/>
                <MenuItem Header="_Open Project"
                          Command="{Binding OpenProjectCommand}"
                          InputGestureText="Ctrl+O"
                          AutomationProperties.Name="Open project, Control O"/>
                <Separator/>
                <MenuItem Header="_Save"
                          Command="{Binding SaveProjectCommand}"
                          InputGestureText="Ctrl+S"
                          AutomationProperties.Name="Save, Control S"/>
                <MenuItem Header="Save _As"
                          Command="{Binding SaveProjectAsCommand}"
                          InputGestureText="Ctrl+Shift+S"
                          AutomationProperties.Name="Save as, Control Shift S"/>
                <Separator/>
                <MenuItem Header="_Import .docx..."
                          Command="{Binding ImportDocumentCommand}"
                          InputGestureText="Ctrl+I"
                          AutomationProperties.Name="Import Word document, Control I"
                          AutomationProperties.HelpText="Import a Word .docx file. Claude will detect chapter breaks and guide you through the import."/>
                <Separator/>
                <MenuItem Header="Export _Manuscript (.docx)..."
                          Command="{Binding ExportDocxCommand}"
                          AutomationProperties.Name="Export manuscript as Word document"
                          AutomationProperties.HelpText="Export all sections to a formatted Word .docx file, ordered front matter, body chapters, back matter."/>
                <MenuItem Header="Export as _PDF..."
                          Command="{Binding ExportPdfCommand}"
                          AutomationProperties.Name="Export manuscript as PDF"
                          AutomationProperties.HelpText="Export all sections to a formatted PDF file with title page, running header, and page numbers."/>
                <Separator/>
                <MenuItem Header="E_xit"
                          Click="ExitMenuItem_Click"
                          AutomationProperties.Name="Exit application"/>
            </MenuItem>

            <MenuItem Header="_Chapters" AutomationProperties.Name="Chapters menu">
                <MenuItem Header="_Add Chapter"
                          Command="{Binding AddChapterCommand}"
                          InputGestureText="Ctrl+A"
                          AutomationProperties.Name="Add chapter, Control A"/>
                <MenuItem Header="_Rename Chapter"
                          Command="{Binding RenameChapterCommand}"
                          InputGestureText="Ctrl+D"
                          AutomationProperties.Name="Rename chapter, Control D"/>
                <MenuItem Header="_Delete Chapter"
                          Command="{Binding DeleteChapterCommand}"
                          InputGestureText="Ctrl+Delete"
                          AutomationProperties.Name="Delete chapter, Control Delete"/>
                <Separator/>
                <MenuItem Header="Move _Up"
                          Command="{Binding MoveChapterUpCommand}"
                          InputGestureText="Alt+Up"
                          AutomationProperties.Name="Move chapter up, Alt Up arrow"/>
                <MenuItem Header="Move _Down"
                          Command="{Binding MoveChapterDownCommand}"
                          InputGestureText="Alt+Down"
                          AutomationProperties.Name="Move chapter down, Alt Down arrow"/>
            </MenuItem>

            <MenuItem Header="_AI" AutomationProperties.Name="AI menu">
                <MenuItem Header="{Binding ApiKeyStatusDisplay}"
                          Command="{Binding SetApiKeyCommand}"
                          AutomationProperties.Name="{Binding ApiKeyStatusDisplay}"
                          AutomationProperties.HelpText="Configure your Anthropic API key for AI features"/>
                <Separator/>
                <MenuItem Header="_Comprehensive Feedback"
                          Command="{Binding RunAiFeedbackCommand}"
                          CommandParameter="comprehensive"
                          InputGestureText="Ctrl+F"
                          AutomationProperties.Name="Comprehensive feedback, Control F"/>
                <MenuItem Header="_Pacing"
                          Command="{Binding RunAiFeedbackCommand}"
                          CommandParameter="pacing"
                          AutomationProperties.Name="Pacing analysis"/>
                <MenuItem Header="_Dialogue"
                          Command="{Binding RunAiFeedbackCommand}"
                          CommandParameter="dialogue"
                          AutomationProperties.Name="Dialogue analysis"/>
                <MenuItem Header="_Style"
                          Command="{Binding RunAiFeedbackCommand}"
                          CommandParameter="style"
                          AutomationProperties.Name="Style analysis"/>
                <MenuItem Header="S_tructure"
                          Command="{Binding RunAiFeedbackCommand}"
                          CommandParameter="structure"
                          AutomationProperties.Name="Structure analysis"/>
            </MenuItem>

            <MenuItem Header="_Settings" AutomationProperties.Name="Settings menu">
                <MenuItem Header="Configure _Voice..."
                          Command="{Binding ConfigureVoiceCommand}"
                          AutomationProperties.Name="Configure voice — set up Azure neural TTS or choose Windows voice"
                          AutomationProperties.HelpText="Open voice configuration to set up Azure Neural TTS or install better Windows voices"/>
                <MenuItem Header="{Binding VoiceStatusDisplay}"
                          IsEnabled="False"
                          AutomationProperties.Name="{Binding VoiceStatusDisplay}"/>
                <Separator/>
                <MenuItem Header="{Binding AppTtsStatusDisplay}"
                          Command="{Binding ToggleAppTtsCommand}"
                          AutomationProperties.Name="{Binding AppTtsStatusDisplay}"
                          AutomationProperties.HelpText="Toggle app text-to-speech. When off, JAWS handles all audio."/>
                <Separator/>
                <MenuItem Header="{Binding JawsStatusDisplay}"
                          IsEnabled="False"
                          AutomationProperties.Name="{Binding JawsStatusDisplay}"/>
            </MenuItem>

            <MenuItem Header="_Help" AutomationProperties.Name="Help menu">
                <MenuItem Header="Keyboard _Shortcuts"
                          Click="ShowShortcuts_Click"
                          AutomationProperties.Name="Show keyboard shortcuts"/>
                <MenuItem Header="_About"
                          Click="ShowAbout_Click"
                          AutomationProperties.Name="About VoiceBook Studio"/>
            </MenuItem>
        </Menu>

        <!-- ============================================================
             TOOLBAR
             ============================================================ -->
        <ToolBar Grid.Row="1" ToolBarTray.IsLocked="True"
                 AutomationProperties.Name="Quick action toolbar">

            <Button Command="{Binding NewProjectCommand}"
                    ToolTip="New Project (Ctrl+N)"
                    TabIndex="1"
                    AutomationProperties.Name="New project"
                    AutomationProperties.HelpText="Create a new VoiceBook project, Control N">
                <TextBlock Text="New" FontWeight="Bold"/>
            </Button>
            <Button Command="{Binding OpenProjectCommand}"
                    ToolTip="Open Project (Ctrl+O)"
                    TabIndex="2"
                    AutomationProperties.Name="Open project"
                    AutomationProperties.HelpText="Open an existing .vbk project file, Control O">
                <TextBlock Text="Open"/>
            </Button>
            <Button Command="{Binding SaveProjectCommand}"
                    ToolTip="Save (Ctrl+S)"
                    TabIndex="3"
                    AutomationProperties.Name="Save project"
                    AutomationProperties.HelpText="Save the current project, Control S">
                <TextBlock Text="Save"/>
            </Button>
            <Button Command="{Binding ImportDocumentCommand}"
                    ToolTip="Import .docx (Ctrl+I)"
                    TabIndex="4"
                    AutomationProperties.Name="Import Word document"
                    AutomationProperties.HelpText="Import a Word .docx file with Claude chapter detection, Control I">
                <TextBlock Text="Import .docx"/>
            </Button>

            <Separator/>

            <Button Command="{Binding AddChapterCommand}"
                    ToolTip="Add Chapter (Ctrl+A)"
                    TabIndex="5"
                    AutomationProperties.Name="Add chapter"
                    AutomationProperties.HelpText="Add a new chapter to the project, Control A">
                <TextBlock Text="+ Chapter"/>
            </Button>
            <Button Command="{Binding MoveChapterUpCommand}"
                    ToolTip="Move Chapter Up (Alt+Up)"
                    TabIndex="6"
                    AutomationProperties.Name="Move chapter up"
                    AutomationProperties.HelpText="Move the selected chapter up in the list, Alt Up arrow">
                <TextBlock Text="&#x2191; Up"/>
            </Button>
            <Button Command="{Binding MoveChapterDownCommand}"
                    ToolTip="Move Chapter Down (Alt+Down)"
                    TabIndex="7"
                    AutomationProperties.Name="Move chapter down"
                    AutomationProperties.HelpText="Move the selected chapter down in the list, Alt Down arrow">
                <TextBlock Text="&#x2193; Down"/>
            </Button>

            <Separator/>

            <!-- API key status — clickable, colour-coded -->
            <Button Command="{Binding SetApiKeyCommand}"
                    ToolTip="Click to configure Anthropic API key"
                    TabIndex="8"
                    AutomationProperties.Name="{Binding ApiKeyStatusDisplay}"
                    AutomationProperties.HelpText="Click to open API key configuration dialog">
                <TextBlock x:Name="ApiKeyStatusText"
                           Text="{Binding ApiKeyStatusDisplay}"
                           FontWeight="Bold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="DarkOrange"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsApiKeySet}" Value="True">
                                    <Setter Property="Foreground" Value="DarkGreen"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Button>

            <Separator/>

            <TextBlock Text="{Binding JawsStatusDisplay}"
                       VerticalAlignment="Center" Margin="4,0"
                       Foreground="DarkGreen"
                       AutomationProperties.Name="{Binding JawsStatusDisplay}"
                       AutomationProperties.LiveSetting="Polite"/>

            <Button Command="{Binding ToggleAppTtsCommand}"
                    Content="{Binding AppTtsStatusDisplay}"
                    ToolTip="Toggle app text-to-speech"
                    TabIndex="9"
                    AutomationProperties.Name="{Binding AppTtsStatusDisplay}"
                    AutomationProperties.HelpText="Toggle app voice on or off. JAWS always runs independently."/>
        </ToolBar>

        <!-- ============================================================
             THREE-PANEL LAYOUT
             ============================================================ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="180" MaxWidth="400"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="300" MinWidth="220" MaxWidth="460"/>
            </Grid.ColumnDefinitions>

            <!-- ============================================================
                 PANEL 1 — CHAPTERS
                 ============================================================ -->
            <Grid Grid.Column="0" x:Name="ChaptersPanel" Background="#F5F5F5"
                  AutomationProperties.Name="Chapters panel, F1 to focus">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1565C0" Padding="10,8">
                    <TextBlock Text="CHAPTERS  (F1)"
                               Foreground="White" FontWeight="Bold" FontSize="12"
                               AutomationProperties.Name="Chapters panel. Press F1 to focus."/>
                </Border>

                <ListBox Grid.Row="1"
                         x:Name="ChapterListBox"
                         ItemsSource="{Binding Chapters}"
                         SelectedItem="{Binding SelectedChapter}"
                         SelectionChanged="ChapterListBox_SelectionChanged"
                         Margin="4"
                         TabIndex="20"
                         AutomationProperties.Name="Chapter list"
                         AutomationProperties.HelpText="Select a chapter to edit. Use arrow keys to navigate. Front matter, body chapters, and back matter are shown in order.">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2,2">
                                <TextBlock Text="{Binding ChapterListLabel}"
                                           FontSize="13" TextWrapping="Wrap"
                                           AutomationProperties.Name="{Binding ChapterListLabel}"/>
                                <TextBlock Text="{Binding SectionGroup}"
                                           FontSize="10" Foreground="#888"
                                           AutomationProperties.Name="{Binding SectionGroup}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="AutomationProperties.Name"
                                    Value="{Binding ChapterListLabel}"/>
                            <Setter Property="AutomationProperties.HelpText"
                                    Value="{Binding SectionGroup}"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <StackPanel Grid.Row="2" Margin="4">
                    <Button Command="{Binding AddChapterCommand}"
                            Content="Add Chapter (Ctrl+A)" Padding="6,5" Margin="0,0,0,4"
                            TabIndex="21"
                            AutomationProperties.Name="Add chapter, Control A"
                            AutomationProperties.HelpText="Add a new chapter to the project"/>
                    <Button Command="{Binding RenameChapterCommand}"
                            Content="Rename (Ctrl+D)" Padding="6,5" Margin="0,0,0,4"
                            TabIndex="22"
                            AutomationProperties.Name="Rename chapter, Control D"
                            AutomationProperties.HelpText="Rename the selected chapter"/>
                    <Button Command="{Binding DeleteChapterCommand}"
                            Content="Delete (Ctrl+Del)" Padding="6,5" Margin="0,0,0,4"
                            TabIndex="23"
                            AutomationProperties.Name="Delete chapter, Control Delete"
                            AutomationProperties.HelpText="Permanently delete the selected chapter"/>
                    <Button Command="{Binding ChangeChapterTypeCommand}"
                            Content="Change Type..." Padding="6,5" Margin="0,0,0,4"
                            TabIndex="24"
                            AutomationProperties.Name="Change section type"
                            AutomationProperties.HelpText="Change whether this is a chapter, dedication, appendix, or other section type"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding MoveChapterUpCommand}"
                                Content="&#x2191; Move Up" Padding="6,5"
                                TabIndex="25"
                                AutomationProperties.Name="Move chapter up, Alt Up arrow"
                                AutomationProperties.HelpText="Move the selected chapter earlier in the book"/>
                        <Button Grid.Column="2" Command="{Binding MoveChapterDownCommand}"
                                Content="&#x2193; Move Down" Padding="6,5"
                                TabIndex="26"
                                AutomationProperties.Name="Move chapter down, Alt Down arrow"
                                AutomationProperties.HelpText="Move the selected chapter later in the book"/>
                    </Grid>
                </StackPanel>
            </Grid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          IsTabStop="False"
                          AutomationProperties.Name="Resize chapters panel"/>

            <!-- ============================================================
                 PANEL 2 — EDITOR
                 ============================================================ -->
            <Grid Grid.Column="2" x:Name="EditorPanel"
                  AutomationProperties.Name="Editor panel, F2 to focus">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1565C0" Padding="10,8">
                    <TextBlock Text="{Binding EditorTitle, StringFormat='EDITOR — {0}  (F2)'}"
                               Foreground="White" FontWeight="Bold" FontSize="13"
                               AutomationProperties.Name="{Binding EditorTitle}"
                               AutomationProperties.LiveSetting="Polite"/>
                </Border>

                <TextBlock Grid.Row="1"
                           Text="{Binding WordCountDisplay}"
                           Margin="10,4" FontSize="12" Foreground="#555"
                           AutomationProperties.Name="{Binding WordCountDisplay}"
                           AutomationProperties.LiveSetting="Polite"/>

                <TextBox Grid.Row="2"
                         x:Name="EditorBox"
                         Margin="4"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         FontFamily="Segoe UI"
                         FontSize="14"
                         IsEnabled="{Binding HasSelectedChapter}"
                         TextChanged="EditorBox_TextChanged"
                         LostFocus="EditorBox_LostFocus"
                         TabIndex="30"
                         AutomationProperties.Name="Chapter editor"
                         AutomationProperties.HelpText="Type or dictate your chapter content here. F2 to focus. Dragon NaturallySpeaking dictation is active in this field."/>
            </Grid>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                          IsTabStop="False"
                          AutomationProperties.Name="Resize AI panel"/>

            <!-- ============================================================
                 PANEL 3 — AI ASSISTANT (Chat | Prompts | Cards)
                 ============================================================ -->
            <Grid Grid.Column="4" x:Name="AiPanel" Background="#F5F5F5"
                  AutomationProperties.Name="AI assistant panel, F3 to focus">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Header -->
                    <RowDefinition Height="*"/>      <!-- TabControl -->
                </Grid.RowDefinitions>

                <!-- Header with API status -->
                <Border Grid.Row="0" Background="#1565C0" Padding="10,8">
                    <DockPanel>
                        <TextBlock Text="AI ASSISTANT  (F3)"
                                   Foreground="White" FontWeight="Bold" FontSize="12"
                                   DockPanel.Dock="Left" VerticalAlignment="Center"
                                   AutomationProperties.Name="AI assistant panel. Press F3 to focus."/>
                        <Button DockPanel.Dock="Right"
                                Command="{Binding SetApiKeyCommand}"
                                Background="Transparent" BorderThickness="0"
                                Padding="4,0"
                                TabIndex="39"
                                ToolTip="Click to configure API key"
                                AutomationProperties.Name="{Binding ApiKeyStatusDisplay}"
                                AutomationProperties.HelpText="Click to open API key configuration dialog">
                            <TextBlock Text="{Binding ApiKeyStatusDisplay}"
                                       FontSize="11" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="Orange"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsApiKeySet}" Value="True">
                                                <Setter Property="Foreground" Value="LightGreen"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </DockPanel>
                </Border>

                <!-- Tab control: Chat | Prompts | Cards -->
                <TabControl Grid.Row="1" x:Name="AiTabControl"
                            AutomationProperties.Name="AI assistant tabs. Chat, Prompts, Cards.">

                    <!-- ================================================
                         TAB 1 — CHAT
                         ================================================ -->
                    <TabItem Header="Chat"
                             AutomationProperties.Name="Chat tab">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- Feedback buttons -->
                                <RowDefinition Height="*"/>      <!-- AI response text -->
                                <RowDefinition Height="Auto"/>   <!-- Save as Card -->
                                <RowDefinition Height="Auto"/>   <!-- Insert buttons -->
                                <RowDefinition Height="Auto"/>   <!-- Chat input -->
                            </Grid.RowDefinitions>

                            <!-- Feedback type buttons -->
                            <StackPanel Grid.Row="0" Margin="4">
                                <Button Command="{Binding RunAiFeedbackCommand}"
                                        CommandParameter="comprehensive"
                                        Content="Comprehensive (Ctrl+F)" Padding="6,5" Margin="0,0,0,4"
                                        TabIndex="40"
                                        AutomationProperties.Name="Run comprehensive feedback, Control F"
                                        AutomationProperties.HelpText="Get overall feedback on pacing, dialogue, style and structure"/>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/><ColumnDefinition Width="4"/>
                                        <ColumnDefinition/><ColumnDefinition Width="4"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Command="{Binding RunAiFeedbackCommand}"
                                            CommandParameter="pacing" Content="Pacing" Padding="4,5"
                                            TabIndex="41"
                                            AutomationProperties.Name="Run pacing analysis"
                                            AutomationProperties.HelpText="Analyze chapter for pacing issues, where it drags or rushes"/>
                                    <Button Grid.Column="2" Command="{Binding RunAiFeedbackCommand}"
                                            CommandParameter="dialogue" Content="Dialogue" Padding="4,5"
                                            TabIndex="42"
                                            AutomationProperties.Name="Run dialogue analysis"
                                            AutomationProperties.HelpText="Analyze dialogue naturalness, character voice, and dialogue tags"/>
                                    <Button Grid.Column="4" Command="{Binding RunAiFeedbackCommand}"
                                            CommandParameter="style" Content="Style" Padding="4,5"
                                            TabIndex="43"
                                            AutomationProperties.Name="Run style analysis"
                                            AutomationProperties.HelpText="Analyze prose style, repeated words, passive voice, weak verbs"/>
                                </Grid>
                                <Button Command="{Binding RunAiFeedbackCommand}"
                                        CommandParameter="structure"
                                        Content="Structure" Padding="6,5"
                                        TabIndex="44"
                                        AutomationProperties.Name="Run structure analysis"
                                        AutomationProperties.HelpText="Analyze chapter structure, hook, transitions, and ending"/>
                            </StackPanel>

                            <!-- AI response text -->
                            <TextBox Grid.Row="1"
                                     Margin="4"
                                     x:Name="AiFeedbackBox"
                                     Text="{Binding AiFeedbackText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontSize="12"
                                     Background="#FAFAFA"
                                     TabIndex="45"
                                     AutomationProperties.Name="AI response text"
                                     AutomationProperties.HelpText="AI analysis or chat response appears here. Use Insert buttons below to add it to your chapter, or Save as Card to keep it for later."
                                     AutomationProperties.LiveSetting="Polite"/>

                            <!-- Save as Card button -->
                            <Border Grid.Row="2" Background="#E8F5E9" Padding="4,4"
                                    Visibility="{Binding HasAiResponse,
                                                 Converter={StaticResource BoolToVisibility}}">
                                <Button Command="{Binding SaveAsCardCommand}"
                                        Content="Save as Card..."
                                        Padding="6,4" FontSize="11"
                                        TabIndex="46"
                                        AutomationProperties.Name="Save AI response as a response card"
                                        AutomationProperties.HelpText="Save the current AI response as a reusable card. You will be asked for a title and category."/>
                            </Border>

                            <!-- INSERT buttons — 3 options -->
                            <Border Grid.Row="3" Background="#E8EAF6" Padding="4,6">
                                <StackPanel>
                                    <TextBlock Text="Insert AI response into chapter:"
                                               FontSize="11" FontWeight="Bold" Foreground="#333"
                                               Margin="0,0,0,4"
                                               AutomationProperties.Name="Insert AI response into chapter options"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Command="{Binding InsertAtCursorCommand}"
                                                Content="At Cursor"
                                                Padding="4,5" FontSize="11"
                                                TabIndex="47"
                                                ToolTip="Insert at the last cursor position in the editor before you opened the AI panel"
                                                AutomationProperties.Name="Insert at cursor position"
                                                AutomationProperties.HelpText="Insert AI response where your cursor was in the editor before you switched to this panel"/>
                                        <Button Grid.Column="2"
                                                Command="{Binding InsertAtStartCommand}"
                                                Content="At Start"
                                                Padding="4,5" FontSize="11"
                                                TabIndex="48"
                                                ToolTip="Insert at the beginning of the chapter"
                                                AutomationProperties.Name="Insert at beginning of chapter"
                                                AutomationProperties.HelpText="Insert AI response at the very beginning of the chapter text"/>
                                        <Button Grid.Column="4"
                                                Command="{Binding InsertAtEndCommand}"
                                                Content="At End"
                                                Padding="4,5" FontSize="11"
                                                TabIndex="49"
                                                ToolTip="Insert at the end of the chapter"
                                                AutomationProperties.Name="Insert at end of chapter"
                                                AutomationProperties.HelpText="Insert AI response at the very end of the chapter text"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Chat input row -->
                            <Grid Grid.Row="4" Margin="4,4,4,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         x:Name="ChatInputBox"
                                         Text="{Binding ChatInputText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12"
                                         Padding="4"
                                         TextWrapping="Wrap"
                                         MaxHeight="60"
                                         VerticalScrollBarVisibility="Auto"
                                         KeyDown="ChatInputBox_KeyDown"
                                         TabIndex="50"
                                         AutomationProperties.Name="Chat input field"
                                         AutomationProperties.HelpText="Type a question for Claude and press Enter to send. To run a voice command, type exclamation mark then the command and press Enter, for example: exclamation mark panel 1, or exclamation mark feedback."/>
                                <Button Grid.Column="2"
                                        Command="{Binding SendChatCommand}"
                                        Content="Send"
                                        Padding="10,5"
                                        TabIndex="51"
                                        AutomationProperties.Name="Send chat message to Claude"
                                        AutomationProperties.HelpText="Send your question to Claude AI"/>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- ================================================
                         TAB 2 — PROMPTS
                         ================================================ -->
                    <TabItem Header="Prompts"
                             AutomationProperties.Name="Prompts tab">
                        <Grid Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- Category filter -->
                                <RowDefinition Height="*"/>      <!-- Prompt list -->
                                <RowDefinition Height="Auto"/>   <!-- Preview -->
                                <RowDefinition Height="Auto"/>   <!-- Use button -->
                            </Grid.RowDefinitions>

                            <!-- Category filter -->
                            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="Category:"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"
                                           AutomationProperties.Name="Filter prompts by category"/>
                                <ComboBox ItemsSource="{Binding PromptLibVM.Categories}"
                                          SelectedItem="{Binding PromptLibVM.SelectedCategory}"
                                          TabIndex="53"
                                          AutomationProperties.Name="Prompt category filter"
                                          AutomationProperties.HelpText="Filter the prompt list by category. Select All to see every prompt."/>
                            </DockPanel>

                            <!-- Prompt list -->
                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding PromptLibVM.Prompts}"
                                     SelectedItem="{Binding PromptLibVM.SelectedPrompt}"
                                     TabIndex="54"
                                     AutomationProperties.Name="Writing prompts list"
                                     AutomationProperties.HelpText="Select a prompt and click Use Prompt to load it into the chat box. Say Use prompt followed by the ID, such as F5, to load by voice.">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2">
                                            <TextBlock Text="{Binding DisplayLabel}"
                                                       FontWeight="SemiBold" FontSize="12"
                                                       AutomationProperties.Name="{Binding DisplayLabel}"/>
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="11" Foreground="#666"
                                                       AutomationProperties.Name="{Binding Category}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="AutomationProperties.Name"
                                                Value="{Binding DisplayLabel}"/>
                                        <Setter Property="AutomationProperties.HelpText"
                                                Value="{Binding Preview}"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>

                            <!-- Preview of selected prompt -->
                            <Border Grid.Row="2" BorderBrush="#CCC" BorderThickness="1"
                                    Margin="0,4,0,0" Height="70">
                                <TextBox Text="{Binding PromptLibVM.SelectedPrompt.Preview,
                                                         Mode=OneWay,
                                                         FallbackValue=''}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontSize="11"
                                         Background="#FAFAFA"
                                         BorderThickness="0"
                                         Padding="4"
                                         TabIndex="55"
                                         AutomationProperties.Name="Prompt content preview"
                                         AutomationProperties.HelpText="Preview of the selected prompt text."/>
                            </Border>

                            <!-- Use Prompt button -->
                            <Button Grid.Row="3"
                                    Command="{Binding PromptLibVM.UsePromptCommand}"
                                    Content="Use Prompt"
                                    Padding="6,5" Margin="0,6,0,0"
                                    TabIndex="56"
                                    AutomationProperties.Name="Use selected prompt"
                                    AutomationProperties.HelpText="Load the selected prompt into the chat input box, then switch to the Chat tab so you can review and send it."/>
                        </Grid>
                    </TabItem>

                    <!-- ================================================
                         TAB 3 — RESPONSE CARDS
                         ================================================ -->
                    <TabItem Header="Cards"
                             AutomationProperties.Name="Response Cards tab">
                        <panels:ResponseCardPanel x:Name="ResponseCardPanelInstance"/>
                    </TabItem>

                </TabControl>
            </Grid>
        </Grid>

        <!-- ============================================================
             STATUS BAR
             ============================================================ -->
        <StatusBar Grid.Row="3" AutomationProperties.Name="Status bar">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           AutomationProperties.Name="{Binding StatusMessage}"
                           AutomationProperties.LiveSetting="Polite"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding WordCountDisplay}"
                           FontSize="12" Margin="0,0,8,0"
                           AutomationProperties.Name="{Binding WordCountDisplay}"
                           AutomationProperties.LiveSetting="Polite"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
