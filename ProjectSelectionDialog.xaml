<Window x:Class="VoiceBookStudio.Views.ProjectSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Project — VoiceBook Studio"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="ToolWindow"
        Loaded="Window_Loaded"
        AutomationProperties.Name="Select project dialog"
        AutomationProperties.HelpText="Open a recent project, create a new one, or browse for an existing project file">

    <DockPanel Margin="16" Width="600" Height="420">

        <TextBlock DockPanel.Dock="Top"
                   Text="Which project would you like to work on?"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,6"
                   AutomationProperties.Name="Which project would you like to work on heading"/>

        <TextBlock DockPanel.Dock="Top"
                   TextWrapping="Wrap" Margin="0,0,0,12" FontSize="12" Foreground="#555"
                   AutomationProperties.Name="Select a recent project from the list, or use the buttons below to create a new project or browse for an existing file.">
            Select a recent project from the list, or use the buttons below
            to create a new project or browse for an existing file.
        </TextBlock>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="OpenButton"
                    Width="130" Margin="0,0,8,0"
                    IsDefault="True"
                    TabIndex="2"
                    Click="OpenButton_Click"
                    AutomationProperties.Name="Open selected project"
                    AutomationProperties.HelpText="Open the project selected in the list above">
                Open Selected
            </Button>
            <Button x:Name="NewButton"
                    Width="130" Margin="0,0,8,0"
                    TabIndex="3"
                    Click="NewButton_Click"
                    AutomationProperties.Name="Create new project"
                    AutomationProperties.HelpText="Create a brand-new VoiceBook project">
                Create New
            </Button>
            <Button x:Name="BrowseButton"
                    Width="130"
                    TabIndex="4"
                    Click="BrowseButton_Click"
                    AutomationProperties.Name="Browse for existing project file"
                    AutomationProperties.HelpText="Open a file browser to locate an existing dot vbk project file">
                Browse...
            </Button>
        </StackPanel>

        <ListBox x:Name="ProjectsList"
                 DockPanel.Dock="Top"
                 ItemsSource="{Binding RecentProjects}"
                 SelectedItem="{Binding SelectedProject}"
                 DisplayMemberPath="Name"
                 TabIndex="1"
                 AutomationProperties.Name="Recent projects list"
                 AutomationProperties.HelpText="Use arrow keys to select a project, then press Open Selected or press Enter."/>
    </DockPanel>
</Window>
