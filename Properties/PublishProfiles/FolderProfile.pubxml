<?xml version="1.0" encoding="utf-8"?>
<!--
  Self-contained win-x64 publish profile.
  Output goes to C:\Dev\VoiceBook\VoiceBookStudio\publish\  (solution root)
  No .NET 8 runtime required on the end-user PC.
  Run via: dotnet publish VoiceBookStudio.csproj /p:PublishProfile=FolderProfile
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <!-- Subfolder of the project dir — .iss sources from publish\* relative to itself -->
    <PublishDir>C:\Dev\VoiceBook\VoiceBookStudio\publish\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>true</PublishReadyToRun>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>false</EnableCompressionInSingleFile>
  </PropertyGroup>
</Project>