<UserControl x:Class="VoiceBookStudio.Views.Panels.ResponseCardPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.Name="Response Cards panel">

    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Filter row -->
            <RowDefinition Height="*"/>      <!-- Card list -->
            <RowDefinition Height="100"/>    <!-- Preview -->
            <RowDefinition Height="Auto"/>   <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Category filter -->
        <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <TextBlock DockPanel.Dock="Left"
                       Text="Category:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"
                       AutomationProperties.Name="Filter by category"/>
            <ComboBox ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      TabIndex="60"
                      AutomationProperties.Name="Category filter"
                      AutomationProperties.HelpText="Filter cards by category. Select All to see every card."/>
        </DockPanel>

        <!-- Card list -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Cards}"
                 SelectedItem="{Binding SelectedCard}"
                 Margin="0,0,0,6"
                 TabIndex="61"
                 AutomationProperties.Name="Response cards list"
                 AutomationProperties.HelpText="Select a card to preview its content. Use arrow keys to navigate.">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="2">
                        <TextBlock Text="{Binding Title}"
                                   FontWeight="SemiBold" FontSize="12"
                                   AutomationProperties.Name="{Binding Title}"/>
                        <TextBlock Text="{Binding Category}"
                                   FontSize="11" Foreground="#666"
                                   AutomationProperties.Name="{Binding Category}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="6,4"/>
                    <Setter Property="AutomationProperties.Name"
                            Value="{Binding Title}"/>
                    <Setter Property="AutomationProperties.HelpText"
                            Value="{Binding Category}"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- Preview -->
        <Border Grid.Row="2" BorderBrush="#CCC" BorderThickness="1"
                Margin="0,0,0,6">
            <TextBox Text="{Binding PreviewText, Mode=OneWay}"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontSize="11"
                     Background="#FAFAFA"
                     BorderThickness="0"
                     Padding="4"
                     TabIndex="62"
                     AutomationProperties.Name="Card content preview"
                     AutomationProperties.HelpText="Read-only preview of the selected card content."/>
        </Border>

        <!-- Action buttons -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Command="{Binding InsertCardCommand}"
                    Content="Insert Card"
                    Padding="6,5"
                    TabIndex="63"
                    AutomationProperties.Name="Insert selected card into editor"
                    AutomationProperties.HelpText="Insert the selected card content at the cursor position in the editor."/>

            <Button Grid.Column="2"
                    Command="{Binding DeleteCardCommand}"
                    Content="Delete Card"
                    Padding="6,5"
                    TabIndex="64"
                    AutomationProperties.Name="Delete selected card"
                    AutomationProperties.HelpText="Permanently delete the selected card from the library."/>
        </Grid>
    </Grid>
</UserControl>
