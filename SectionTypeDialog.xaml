<Window x:Class="VoiceBookStudio.Views.SectionTypeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Section Type"
        Width="360" Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AutomationProperties.Name="Select section type dialog">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Choose the type of section to add:"
                   FontSize="13" TextWrapping="Wrap"
                   AutomationProperties.Name="Choose the type of section to add"/>

        <!-- Section type list -->
        <ListBox Grid.Row="2"
                 x:Name="TypeListBox"
                 FontSize="13"
                 TabIndex="1"
                 MouseDoubleClick="TypeListBox_MouseDoubleClick"
                 AutomationProperties.Name="Section type list"
                 AutomationProperties.HelpText="Select a section type and press OK, or double-click to confirm.">
            <ListBox.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="Bold" FontSize="11"
                                       Foreground="#555"
                                       Margin="2,6,0,2"
                                       AutomationProperties.Name="{Binding Name}"/>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListBox.GroupStyle>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="8,5"/>
                    <Setter Property="AutomationProperties.Name" Value="{Binding DisplayName}"/>
                    <Setter Property="AutomationProperties.HelpText" Value="{Binding GroupName}"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}" FontSize="13"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="OkButton"
                    Content="OK"
                    IsDefault="True"
                    Margin="0,0,8,0"
                    TabIndex="2"
                    AutomationProperties.Name="OK"
                    Click="OkButton_Click"/>
            <Button Content="Cancel"
                    IsCancel="True"
                    TabIndex="3"
                    AutomationProperties.Name="Cancel"/>
        </StackPanel>
    </Grid>
</Window>
