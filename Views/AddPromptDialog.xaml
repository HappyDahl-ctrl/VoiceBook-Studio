<Window x:Class="VoiceBookStudio.Views.AddPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Prompt"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        AutomationProperties.Name="Add new prompt dialog">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Live region — code-behind sets Text in Window_Loaded to announce the dialog to JAWS. -->
        <TextBlock x:Name="AnnouncementRegion"
                   AutomationProperties.LiveSetting="Assertive"
                   Text="" Height="0" Focusable="False"
                   Grid.RowSpan="8"/>

        <!-- Label TextBlocks are visual companions to named fields; excluded from UIA. -->
        <TextBlock Grid.Row="0" Text="Prompt title:"
                   Margin="0,0,0,4" FontWeight="SemiBold"
                   />
        <TextBox Grid.Row="1" x:Name="TitleBox"
                 Margin="0,0,0,12" Padding="4"
                 AutomationProperties.Name="Prompt title"
                 AutomationProperties.HelpText="Enter a short descriptive title for this prompt"/>

        <TextBlock Grid.Row="2" Text="Prompt text:"
                   Margin="0,0,0,4" FontWeight="SemiBold"
                   />
        <TextBox Grid.Row="3" x:Name="ContentBox"
                 Height="100" AcceptsReturn="True"
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,12" Padding="4"
                 AutomationProperties.Name="Prompt text"
                 AutomationProperties.HelpText="Type the full prompt text that will be sent to Claude"/>

        <TextBlock Grid.Row="4" Text="Category:"
                   Margin="0,0,0,4" FontWeight="SemiBold"
                   />
        <Grid Grid.Row="5" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0" x:Name="CategoryCombo"
                      AutomationProperties.Name="Select existing category"
                      AutomationProperties.HelpText="Choose an existing category or check New Category below"/>
            <CheckBox Grid.Column="2" x:Name="NewCategoryCheck"
                      Content="New category"
                      VerticalAlignment="Center"
                      Checked="NewCategoryCheck_Changed"
                      Unchecked="NewCategoryCheck_Changed"
                      AutomationProperties.Name="Create a new category"/>
        </Grid>

        <!-- New category fields — visible when checkbox is checked -->
        <Border Grid.Row="6" x:Name="NewCategoryPanel"
                Visibility="Collapsed" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Category name:"
                           Margin="0,0,0,4"
                           />
                <TextBox Grid.Row="1" x:Name="NewCategoryNameBox"
                         Margin="0,0,0,8" Padding="4"
                         AutomationProperties.Name="New category name"/>
                <TextBlock Grid.Row="2" Text="Category letter (auto-suggested):"
                           Margin="0,0,0,4"
                           />
                <TextBox Grid.Row="3" x:Name="NewCategoryLetterBox"
                         MaxLength="1" Width="40" HorizontalAlignment="Left"
                         Margin="0,0,0,0" Padding="4"
                         AutomationProperties.Name="New category letter"
                         AutomationProperties.HelpText="Single letter A-Z, auto-suggested but editable"/>
            </Grid>
        </Border>

        <!-- OK / Cancel -->
        <Grid Grid.Row="7" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="OkButton"
                    Content="Add Prompt"
                    IsDefault="True"
                    Click="OkButton_Click"
                    Padding="10,5"
                    AutomationProperties.Name="Add prompt"
                    AutomationProperties.HelpText="Save the new prompt to the library. Press Enter to confirm. Voice command: say Add prompt."/>
            <Button Grid.Column="2"
                    Content="Cancel"
                    IsCancel="True"
                    Padding="10,5"
                    AutomationProperties.Name="Cancel"
                    AutomationProperties.HelpText="Close without saving. Press Escape to cancel."/>
        </Grid>
    </Grid>
</Window>
