<Window x:Class="VoiceBookStudio.Views.AzureTtsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure Voice — VoiceBook Studio"
        Width="520" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Loaded="Window_Loaded"
        AutomationProperties.Name="Configure voice dialog"
        AutomationProperties.HelpText="Set up Azure Neural TTS for a natural-sounding human voice, or install free Windows 11 neural voices">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0,4,0,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Live region — code-behind sets Text in Window_Loaded to announce the dialog to JAWS. -->
        <TextBlock x:Name="AnnouncementRegion"
                   AutomationProperties.LiveSetting="Assertive"
                   Text="" Height="0" Focusable="False"
                   Grid.RowSpan="13"/>

        <!-- Heading — visual only; Window AutomationProperties.Name is the JAWS announcement. -->
        <TextBlock Grid.Row="0"
                   Text="Azure Neural Voice Configuration"
                   FontSize="15" FontWeight="Bold"/>

        <!-- Info box -->
        <Border Grid.Row="2" Background="#E3F2FD" BorderBrush="#90CAF9"
                BorderThickness="1" Padding="10,8" CornerRadius="4">
            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#1565C0"
                       AutomationProperties.Name="Information: Free Windows 11 neural voices are also available. Go to Settings, Time and Language, Speech, Manage voices to download Microsoft Aria or Jenny. Those work without an Azure key. Azure gives you more voice choices and better quality.">
                <Run FontWeight="Bold">Free option:</Run>
                <Run> Go to Settings → Time &amp; Language → Speech → Manage voices
and download Microsoft Aria or Jenny. No key needed — they appear
here automatically once installed.</Run>
                <LineBreak/>
                <LineBreak/>
                <Run FontWeight="Bold">Azure option:</Run>
                <Run> Create a free Azure account at portal.azure.com, create a
Speech resource (free tier = 500,000 chars/month), then paste
your key and region below.</Run>
            </TextBlock>
        </Border>

        <!-- API Key — Label is decorative; TextBox has its own name. -->
        <Label Grid.Row="4" Content="Azure Speech Key:"
               IsTabStop="False"
               />
        <TextBox Grid.Row="5" x:Name="KeyBox"
                 TabIndex="1"
                 AutomationProperties.Name="Azure Speech subscription key"
                 AutomationProperties.HelpText="Paste your Azure Cognitive Services Speech subscription key here"/>

        <!-- Region — Label is decorative; TextBox has its own name. -->
        <Label Grid.Row="6" Content="Azure Region (e.g. eastus, westus2, uksouth):"
               IsTabStop="False"
               />
        <TextBox Grid.Row="7" x:Name="RegionBox"
                 TabIndex="2"
                 AutomationProperties.Name="Azure region"
                 AutomationProperties.HelpText="Enter the Azure region where your Speech resource was created, for example: eastus"/>

        <!-- Voice — Label is decorative; ComboBox has its own name. -->
        <Label Grid.Row="8" Content="Voice:"
               IsTabStop="False"
               />
        <ComboBox Grid.Row="9" x:Name="VoiceCombo"
                  TabIndex="3"
                  AutomationProperties.Name="Neural voice selection"
                  AutomationProperties.HelpText="Choose the neural voice for the app to use">
            <ComboBoxItem Tag="en-US-AriaNeural"   Content="Aria — warm, conversational female (recommended)" IsSelected="True"/>
            <ComboBoxItem Tag="en-US-JennyNeural"  Content="Jenny — friendly, clear female"/>
            <ComboBoxItem Tag="en-US-JaneNeural"   Content="Jane — warm, expressive female"/>
            <ComboBoxItem Tag="en-US-GuyNeural"    Content="Guy — casual, natural male"/>
            <ComboBoxItem Tag="en-US-DavisNeural"  Content="Davis — professional male"/>
            <ComboBoxItem Tag="en-US-JasonNeural"  Content="Jason — energetic male"/>
            <ComboBoxItem Tag="en-US-TonyNeural"   Content="Tony — confident male"/>
            <ComboBoxItem Tag="en-US-NancyNeural"  Content="Nancy — pleasant female"/>
        </ComboBox>

        <!-- Status label -->
        <TextBlock Grid.Row="10" x:Name="StatusLabel"
                   FontSize="11" Foreground="#555" FontStyle="Italic"
                   AutomationProperties.LiveSetting="Polite"
                   AutomationProperties.Name="{Binding Text, RelativeSource={RelativeSource Self}}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="TestButton"
                    Content="Test Voice" Margin="0,0,8,0"
                    TabIndex="4"
                    Click="TestButton_Click"
                    AutomationProperties.Name="Test Voice"
                    AutomationProperties.HelpText="Speak a sample sentence to preview the selected voice. Dragon: say click Test Voice."/>
            <Button x:Name="ClearButton"
                    Content="Clear" Margin="0,0,8,0"
                    TabIndex="5"
                    Click="ClearButton_Click"
                    AutomationProperties.Name="Clear"
                    AutomationProperties.HelpText="Remove Azure credentials and revert to Windows voice. Dragon: say click Clear."/>
            <Button Content="Cancel"
                    IsCancel="True"
                    Margin="0,0,8,0"
                    TabIndex="6"
                    AutomationProperties.Name="Cancel"/>
            <Button Content="Save"
                    IsDefault="True"
                    TabIndex="7"
                    Click="SaveButton_Click"
                    AutomationProperties.Name="Save"
                    AutomationProperties.HelpText="Save voice settings. Dragon: say click Save."/>
        </StackPanel>
    </Grid>
</Window>
