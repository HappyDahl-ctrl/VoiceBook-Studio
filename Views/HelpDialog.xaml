<Window x:Class="VoiceBookStudio.Views.HelpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceBook Studio Help"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ThreeDBorderWindow"
        ResizeMode="CanResize"
        Width="680" Height="560"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown"
        AutomationProperties.Name="VoiceBook Studio Help"
        AutomationProperties.HelpText="Help topics. Press a number key 1 through 9 to open a topic. Press Escape to go back to the topic list or close the window.">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Content -->
            <RowDefinition Height="Auto"/>   <!-- Footer hint -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1565C0" Padding="14,10">
            <DockPanel>
                <Button x:Name="BackButton"
                        DockPanel.Dock="Left"
                        Click="BackButton_Click"
                        Padding="10,4" Margin="0,0,12,0"
                        Visibility="Collapsed"
                        AutomationProperties.Name="Back to help topics list"
                        AutomationProperties.HelpText="Return to the list of help topics. Keyboard shortcut: Escape">
                    ← Topics
                </Button>
                <TextBlock x:Name="HeaderLabel"
                           Text="Help Topics"
                           Foreground="White" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center"
                           AutomationProperties.Name="Help Topics"
                           AutomationProperties.LiveSetting="Polite"/>
            </DockPanel>
        </Border>

        <!-- Topic list (shown when no topic selected) -->
        <ListBox x:Name="TopicListBox"
                 Grid.Row="1"
                 Margin="8"
                 FontSize="14"
                 SelectionChanged="Topic_SelectionChanged"
                 AutomationProperties.Name="Help topics list"
                 AutomationProperties.HelpText="Select a topic to read. Press a number key 1 through 9, or use arrow keys and Enter.">
            <ListBoxItem AutomationProperties.Name="1. Getting Started">
                <TextBlock Text="1.  Getting Started" Padding="4,6"/>
            </ListBoxItem>
            <ListBoxItem AutomationProperties.Name="2. Navigating the Three Panels">
                <TextBlock Text="2.  Navigating the Three Panels" Padding="4,6"/>
            </ListBoxItem>
            <ListBoxItem AutomationProperties.Name="3. Managing Chapters and Sections">
                <TextBlock Text="3.  Managing Chapters and Sections" Padding="4,6"/>
            </ListBoxItem>
            <ListBoxItem AutomationProperties.Name="4. Writing in the Editor">
                <TextBlock Text="4.  Writing in the Editor" Padding="4,6"/>
            </ListBoxItem>
            <ListBoxItem AutomationProperties.Name="5. AI Assistant and Feedback">
                <TextBlock Text="5.  AI Assistant and Feedback" Padding="4,6"/>
            </ListBoxItem>
            <ListBoxItem AutomationProperties.Name="6. Voice Commands Reference">
                <TextBlock Text="6.  Voice Commands Reference" Padding="4,6"/>
            </ListBoxItem>
            <ListBoxItem AutomationProperties.Name="7. Dragon NaturallySpeaking and JSay Guide">
                <TextBlock Text="7.  Dragon NaturallySpeaking and JSay Guide" Padding="4,6"/>
            </ListBoxItem>
            <ListBoxItem AutomationProperties.Name="8. Keyboard Shortcuts">
                <TextBlock Text="8.  Keyboard Shortcuts" Padding="4,6"/>
            </ListBoxItem>
            <ListBoxItem AutomationProperties.Name="9. Exporting and Importing">
                <TextBlock Text="9.  Exporting and Importing" Padding="4,6"/>
            </ListBoxItem>
        </ListBox>

        <!-- Topic content (shown when a topic is selected) -->
        <TextBox x:Name="ContentBox"
                 Grid.Row="1"
                 Margin="8"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 FontSize="13"
                 FontFamily="Segoe UI"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled"
                 Background="#FAFAFA"
                 Padding="10"
                 Visibility="Collapsed"
                 AutomationProperties.Name="Help topic content"
                 AutomationProperties.HelpText="Use arrow keys to read line by line. Ctrl+Down moves paragraph by paragraph. Press Escape to return to the topic list."/>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F0F0F0" Padding="10,6">
            <TextBlock x:Name="FooterHint"
                       Text="Press 1–9 to jump to a topic  ·  Enter or click to open  ·  Escape to close"
                       FontSize="11" Foreground="#555"
                       AutomationProperties.Name="Press a number key 1 through 9 to open a topic. Press Escape to go back or close."/>
        </Border>
    </Grid>
</Window>
