<Window x:Class="VoiceBookStudio.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceBook Studio — Settings"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="540" Height="300"
        AutomationProperties.Name="Settings dialog"
        AutomationProperties.HelpText="Configure default project folder and other settings. The current folder path is read aloud when this dialog opens.">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Heading -->
            <RowDefinition Height="*"/>      <!-- Settings area -->
            <RowDefinition Height="Auto"/>   <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Live region — code-behind sets Text in Window_Loaded to announce the dialog to JAWS. -->
        <TextBlock x:Name="AnnouncementRegion"
                   AutomationProperties.LiveSetting="Assertive"
                   Text="" Height="0" Focusable="False"
                   Grid.RowSpan="3"/>

        <!-- Heading — visual only; Window AutomationProperties.Name is the JAWS announcement. -->
        <TextBlock Grid.Row="0"
                   Text="Settings"
                   FontSize="18" FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <!-- Settings area -->
        <StackPanel Grid.Row="1">

            <!-- Default Project Folder -->
            <GroupBox Header="Default Project Folder"
                      Padding="10,8"
                      AutomationProperties.Name="Default project folder settings"
                      AutomationProperties.HelpText="New projects will be saved here automatically without prompting. Leave blank to be asked each time.">
                <StackPanel>
                    <TextBlock Text="New projects will be saved here without prompting. Leave blank to be asked each time."
                               FontSize="12" Foreground="#555"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 x:Name="FolderPathBox"
                                 IsReadOnly="True"
                                 FontSize="12"
                                 Padding="6,4"
                                 VerticalContentAlignment="Center"
                                 TabIndex="1"
                                 AutomationProperties.Name="Default project folder path"
                                 AutomationProperties.HelpText="The current default project folder. Use the Browse button to change it."/>

                        <Button Grid.Column="2"
                                x:Name="BrowseButton"
                                Content="Browse..."
                                Padding="10,5"
                                TabIndex="2"
                                Click="BrowseButton_Click"
                                AutomationProperties.Name="Browse for default project folder"
                                AutomationProperties.HelpText="Open folder picker to select the default project folder. Voice command: say Set project folder."/>

                        <Button Grid.Column="4"
                                x:Name="ClearButton"
                                Content="Clear"
                                Padding="10,5"
                                TabIndex="3"
                                Click="ClearButton_Click"
                                AutomationProperties.Name="Clear default project folder"
                                AutomationProperties.HelpText="Remove the default folder setting — you will be prompted on each save."/>
                    </Grid>

                    <!-- Folder structure note -->
                    <TextBlock Margin="0,10,0,0"
                               FontSize="11" Foreground="#777"
                               TextWrapping="Wrap"
                               Text="Folder structure: [Default Folder]\[ProjectName]\[ProjectName].vbk with a Chapters\ subfolder inside."
                               AutomationProperties.Name="Folder structure: default folder, then project name folder, then project name dot vbk file, with a Chapters subfolder inside."/>
                </StackPanel>
            </GroupBox>

        </StackPanel>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">

            <Button x:Name="SaveButton"
                    Content="Save Settings"
                    IsDefault="True"
                    Padding="14,6"
                    Margin="0,0,8,0"
                    TabIndex="4"
                    Click="SaveButton_Click"
                    AutomationProperties.Name="Save settings and close"
                    AutomationProperties.HelpText="Save all changes and close the settings dialog."/>

            <Button x:Name="CancelButton"
                    Content="Cancel"
                    IsCancel="True"
                    Padding="14,6"
                    TabIndex="5"
                    AutomationProperties.Name="Cancel — discard changes"
                    AutomationProperties.HelpText="Close without saving changes."/>
        </StackPanel>
    </Grid>
</Window>
