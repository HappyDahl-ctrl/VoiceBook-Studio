<Window x:Class="VoiceBookStudio.Views.TutorialDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceBook Tutorial"
        WindowStartupLocation="Manual"
        WindowStyle="ThreeDBorderWindow"
        ResizeMode="CanResize"
        Width="580" Height="560"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown"
        AutomationProperties.Name="Tutorial — VoiceBook Studio"
        AutomationProperties.HelpText="Step-by-step interactive tutorial. N = next, P = previous, R = repeat, S = skip step, Escape = exit. F1/F2/F3 focus app panels without closing this window.">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Step counter -->
            <RowDefinition Height="Auto"/>   <!-- Step title  -->
            <RowDefinition Height="*"/>      <!-- Step body   -->
            <RowDefinition Height="Auto"/>   <!-- Action status (interactive steps only) -->
            <RowDefinition Height="Auto"/>   <!-- Voice command input -->
            <RowDefinition Height="Auto"/>   <!-- Buttons     -->
        </Grid.RowDefinitions>

        <!-- Step counter  e.g. "Step 3 of 10" -->
        <TextBlock Grid.Row="0"
                   Text="{Binding StepCounterDisplay}"
                   FontSize="11" Foreground="#666"
                   Margin="0,0,0,4"
                   AutomationProperties.Name="{Binding StepCounterDisplay}"
                   AutomationProperties.LiveSetting="Polite"/>

        <!-- Step title — announced immediately when it changes -->
        <TextBlock Grid.Row="1"
                   x:Name="StepHeader"
                   Text="{Binding CurrentTitle}"
                   FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,8"
                   AutomationProperties.Name="{Binding CurrentTitle}"
                   AutomationProperties.LiveSetting="Assertive"/>

        <!-- Step instructions — read-only, scrollable -->
        <TextBox Grid.Row="2"
                 x:Name="StepContent"
                 Text="{Binding CurrentContent, Mode=OneWay}"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontSize="13"
                 Padding="8"
                 Background="#FAFAFA"
                 TabIndex="1"
                 AutomationProperties.Name="Step instructions"
                 AutomationProperties.HelpText="Current tutorial step instructions. Read-only."
                 AutomationProperties.LiveSetting="Polite"/>

        <!-- Action status bar — only visible during interactive steps.
             Uses a DataTrigger so no converter is needed. -->
        <Border Grid.Row="3"
                Margin="0,8,0,0"
                Padding="10,8"
                CornerRadius="4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Setter Property="Background"   Value="#FFF8E1"/>
                    <Setter Property="BorderBrush"  Value="#F9A825"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsWaitingForAction}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <TextBlock Text="{Binding ActionStatusText}"
                       TextWrapping="Wrap"
                       FontSize="12"
                       FontStyle="Italic"
                       Foreground="#5D4037"
                       AutomationProperties.Name="{Binding ActionStatusText}"
                       AutomationProperties.LiveSetting="Assertive"/>
        </Border>

        <!-- Voice command input — Dragon users dictate here, all users can type -->
        <DockPanel Grid.Row="4" Margin="0,8,0,0">
            <TextBlock DockPanel.Dock="Left"
                       Text="Command:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       FontSize="12"
                       AutomationProperties.Name="Voice command label"/>
            <TextBox x:Name="CommandInput"
                     FontSize="12"
                     Padding="4,3"
                     VerticalContentAlignment="Center"
                     AutomationProperties.Name="Voice command input"
                     AutomationProperties.HelpText="Dictate or type a voice command here and press Enter. For example: panel two, save, continue, skip step."
                     KeyDown="CommandInput_KeyDown"/>
        </DockPanel>

        <!-- Navigation buttons -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">

            <Button x:Name="PreviousButton"
                    Width="100" Margin="0,0,6,0"
                    Command="{Binding PreviousCommand}"
                    TabIndex="2"
                    AutomationProperties.Name="Previous step"
                    AutomationProperties.HelpText="Go to the previous tutorial step. Keyboard: P">
                Previous
            </Button>

            <Button x:Name="RepeatButton"
                    Width="100" Margin="0,0,6,0"
                    Command="{Binding RepeatCommand}"
                    TabIndex="3"
                    AutomationProperties.Name="Repeat current step"
                    AutomationProperties.HelpText="Repeat the audio for this step. Keyboard: R">
                Repeat
            </Button>

            <!-- Skip button — only visible on skippable interactive steps -->
            <Button x:Name="SkipButton"
                    Width="100" Margin="0,0,6,0"
                    Command="{Binding SkipStepCommand}"
                    TabIndex="4"
                    AutomationProperties.Name="Skip this step"
                    AutomationProperties.HelpText="Skip the current interactive step and continue. Keyboard: S. Voice: say Skip step.">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowSkipButton}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                Skip Step
            </Button>

            <Button x:Name="NextButton"
                    Width="100" Margin="0,0,6,0"
                    IsDefault="True"
                    Command="{Binding NextCommand}"
                    TabIndex="5"
                    AutomationProperties.Name="Next step"
                    AutomationProperties.HelpText="Advance to the next step. Disabled on interactive steps until action is detected. Keyboard: N">
                Next
            </Button>

            <Button x:Name="ExitButton"
                    Width="110"
                    Command="{Binding ExitCommand}"
                    TabIndex="6"
                    AutomationProperties.Name="Exit tutorial"
                    AutomationProperties.HelpText="Close the tutorial and return to the main window. Keyboard: Escape. Voice: say Exit tutorial.">
                Exit Tutorial
            </Button>
        </StackPanel>
    </Grid>
</Window>
