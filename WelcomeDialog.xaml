<Window x:Class="VoiceBookStudio.Views.WelcomeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to VoiceBook Studio"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Loaded="Window_Loaded"
        AutomationProperties.Name="Welcome to VoiceBook Studio dialog"
        AutomationProperties.HelpText="Choose whether to start the tutorial or go directly to the application">

    <StackPanel Margin="20" Width="480">

        <TextBlock Text="Welcome to VoiceBook Studio"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,10"
                   AutomationProperties.Name="Welcome to VoiceBook Studio heading"/>

        <TextBlock TextWrapping="Wrap" Margin="0,0,0,14" FontSize="13"
                   AutomationProperties.Name="Voice-first book writing tools for visually impaired writers. This short tutorial will demonstrate voice commands, microphone and speaker checks, and core workflows.">
            Voice-first book writing tools for visually impaired writers. This short
            tutorial will demonstrate voice commands, microphone and speaker checks,
            and core workflows.
        </TextBlock>

        <CheckBox Name="ShowOnStartupCheckbox"
                  Margin="0,0,0,16"
                  IsChecked="{Binding ShowOnStartup}"
                  AutomationProperties.Name="Don't show this again on startup"
                  AutomationProperties.HelpText="Uncheck to prevent this welcome dialog from appearing every time the application starts">
            Don't show this again on startup
        </CheckBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="StartButton"
                    Width="140" Margin="0,0,10,0"
                    IsDefault="True"
                    Command="{Binding StartTutorialCommand}"
                    Click="StartButton_Click"
                    AutomationProperties.Name="Start tutorial"
                    AutomationProperties.HelpText="Open the step-by-step guided tutorial with voice commands and feature walkthroughs">
                Start Tutorial
            </Button>
            <Button Name="SkipButton"
                    Width="140"
                    IsCancel="True"
                    Command="{Binding SkipTutorialCommand}"
                    Click="SkipButton_Click"
                    AutomationProperties.Name="Skip tutorial, go directly to the main window"
                    AutomationProperties.HelpText="Skip the tutorial and open the main writing window immediately">
                Skip Tutorial
            </Button>
        </StackPanel>
    </StackPanel>
</Window>
